# Groq API Key (required)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (optional, defaults to llama-3.1-8b-instant)
# Options: llama-3.1-8b-instant, llama-3.1-70b-versatile
LLM_MODEL=llama-3.1-8b-instant

# LLM Settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Browser Settings
HEADLESS=true
BROWSER_TIMEOUT=30000

# Agent Settings
MAX_STEPS=20
OBSERVATION_MAX_ELEMENTS=50
